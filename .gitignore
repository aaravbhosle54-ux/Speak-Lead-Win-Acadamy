.env
.env.local
.env.*.local

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp

# Backup files
*.bak
*.backup
*~
